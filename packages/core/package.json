{
  "name": "@campusos/core",
  "private": true,
  "version": "0.1.0",
  "description": "A local-first desktop workspace for ZJU students.",
  "author": "Harry-Linner",
  "type": "module",
  "main": "out/main/main.js",
  "scripts": {
    "predev": "pnpm run rebuild:electron",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node ../../scripts/repair-expect-type.mjs && vitest run",
    "test:e2e": "pnpm run rebuild:electron && electron-vite build --mode e2e && playwright test",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "verify:zju-auth": "node ../../scripts/repair-expect-type.mjs && vitest run src/main/zjuUnifiedAuth.live.test.ts --reporter=verbose",
    "verify:headless-sandbox": "electron-vite build && electron ../../scripts/headless-sandbox-smoke",
    "lint": "node ../../scripts/run-eslint.mjs packages/core"
  },
  "dependencies": {
    "@campusos/plugin-academic-exams": "workspace:*",
    "@campusos/plugin-academic-grades": "workspace:*",
    "@campusos/plugin-academic-scraper": "workspace:*",
    "@campusos/plugin-academic-timetable-events": "workspace:*",
    "@campusos/plugin-calendar": "workspace:*",
    "@campusos/plugin-deadline-assistant": "workspace:*",
    "@campusos/plugin-dingtalk-entry": "workspace:*",
    "@campusos/plugin-exam-countdown": "workspace:*",
    "@campusos/plugin-materials": "workspace:*",
    "@campusos/plugin-zju-calendar-config": "workspace:*",
    "@campusos/plugin-zju-graduate": "workspace:*",
    "@campusos/plugin-zju-learning": "workspace:*",
    "@campusos/plugin-zju-undergraduate": "workspace:*",
    "@campusos/shared": "workspace:*",
    "@jitl/quickjs-wasmfile-release-sync": "0.32.0",
    "@sentry/electron": "^7.15.0",
    "better-sqlite3": "^12.11.1",
    "electron-updater": "^6.8.9",
    "fflate": "0.8.2",
    "quickjs-emscripten-core": "0.32.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "43.1.1",
    "electron-vite": "^3.1.0",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "jsdom": "^26.0.0",
    "playwright": "^1.61.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.8"
  }
}
